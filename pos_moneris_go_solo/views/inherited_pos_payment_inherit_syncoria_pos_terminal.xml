<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="pos_order_syncoria_pos_moneris_terminal_inherit_form_view" model="ir.ui.view">
        <field name="name">pos.order.inherit.form.view.syn.pos.terminal</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="refund_total" invisible="refund_total == 0" readonly="1" force_save="1"/>
                <field name="total_tip_amount" readonly="1" force_save="1"/>
                <field name="total_amount_without_tip" readonly="1" force_save="1"/>
            </xpath>

            <xpath expr="//field[@name='payment_ids']/list/field[@name='amount']" position="after">
                <field name="tip_amount"/>
            </xpath>

            <xpath expr="//field[@name='payment_ids']/list/field[@name='cardholder_name']" position="after">
                <field name="payment_status" readonly="1" force_save="1" optional="show"/>
                <field name="is_refund" readonly="1" force_save="1" optional="hide"/>
                <field name="journal_id" readonly="1" force_save="1" optional="hide"/>

                <button name="open_refund_wizard"
                    type="object"
                    string="Refund"
                    class="btn btn-danger"
                    invisible="payment_status != 'done' or payment_status != 'done' or is_refund == True"/>

                <button name="action_cancel_payment"
                    type="object"
                    string="Cancel"
                    class="btn btn-secondary" confirm="Are you sure you want to cancel?"
                    invisible="payment_status != 'waiting' or is_refund != True"/>

            </xpath>
        </field>
    </record>

    <record id="view_pos_order_tree_inherit_moneris_payment" model="ir.ui.view">
        <field name="name">pos.order.list.inherit.moneris.payment</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="total_amount_without_tip" sum="total_amount_without_tip"/>
                <field name="total_tip_amount" sum="total_tip_amount"/>
            </xpath>
        </field>
    </record>

    <record id="view_pos_payment_tree_inherit_moneris_payment" model="ir.ui.view">
        <field name="name">pos.payment.list.inherit.moneris.payment</field>
        <field name="model">pos.payment</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount']" position="before">
                <field name="card_name"/>
                <field name="tip_amount"/>
            </xpath>
        </field>
    </record>

    <record id="view_pos_payment_form_inherit_moneris_payment" model="ir.ui.view">
        <field name="name">pos.payment.form</field>
        <field name="model">pos.payment</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='transaction_id']" position='after'>
                <field name="tip_amount" readonly="1" force_save="1"/>
                <field name="card_name" readonly="1" force_save="1"/>
            </xpath>
        </field>
    </record>
</odoo>