<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_pos_refund_wizard_form" model="ir.ui.view">
    <field name="name">pos.refund.wizard.form</field>
    <field name="model">pos.refund.wizard</field>
    <field name="arch" type="xml">
        <form string="Refund Customer">
            <group>
                <group>
                    <field name="amount" readonly="1" force_save="1"/>
                    <field name="refund_amount" required="1"/>
                </group>
                <group>
                    <field name="pos_order_id" readonly="1" force_save="1"/>
                </group>
            </group>

            <footer>
                <button string="Submit" type="object" name="confirm_refund" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>
</odoo>